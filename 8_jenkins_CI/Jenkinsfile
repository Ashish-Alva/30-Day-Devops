pipeline {
    agent any

    environment {
        DOCKER_IMAGE_NAME = "ashishalva/hello-python"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('8_jenkins_CI') {
                    script {
                        app = docker.build("${DOCKER_IMAGE_NAME}:latest")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub-credentials') {
                        docker.image("${DOCKER_IMAGE_NAME}:latest").push()
                    }
                }
            }
        }

        stage('Run Container & Show Output') {
            steps {
                sh "docker run --rm ${DOCKER_IMAGE_NAME}:latest"
            }
        }

    }

    post {
        success {
            echo 'Pipeline complete — image built, pushed, and executed!'
        }
        failure {
            echo 'Pipeline failed. Check console output above.'
        }
    }
}